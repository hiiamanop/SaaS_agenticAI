# agenticAI/.env.example
# ================================================================
# ERP Local Development Environment
# To set up: cp .env.example .env  (then edit if needed)
# WARNING: All defaults below are for LOCAL DEV ONLY.
#          Never use these values in staging or production.
# ================================================================

# ---- REQUIRED for local dev --------------------------------
# PostgreSQL, Redis, Qdrant must be running (via make dev)
# Kafka/Vault are optional for basic service development
# ------------------------------------------------------------

# PostgreSQL
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=redis_dev_password
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Kafka / Redpanda
KAFKA_BROKERS=localhost:19092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:18081

# Vault (dev mode — token is static in dev)
VAULT_ADDR=http://localhost:8200
VAULT_DEV_TOKEN=dev-root-token

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Ollama (local LLM — primary in development)
OLLAMA_BASE_URL=http://localhost:11434

# Claude API (fallback in development — optional)
# ANTHROPIC_API_KEY=sk-ant-...

# JWT (dev only — use RS256 keypair in production)
JWT_SECRET=dev-jwt-secret-change-in-production

NODE_ENV=development
LOG_LEVEL=DEBUG
